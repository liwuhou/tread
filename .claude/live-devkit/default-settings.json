{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=require('path'),f=require('fs');for(let d=process.cwd();d!==p.dirname(d);d=p.dirname(d)){const h=p.join(d,'.claude','live-devkit','hooks','check-openspec.cjs');if(f.existsSync(h)){require(h);break}}\""
          }
        ]
      }
    ]
  }
}